<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
  /* ── Password Toggle ── */
  function togglePwd(fieldId, iconId) {
    const field = document.getElementById(fieldId);
    const icon  = document.getElementById(iconId);
    if (field.type === 'password') {
      field.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      field.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  }

  /* ── Basic Form Validation ── */
  document.getElementById('registerForm').addEventListener('submit', function(e) {
    e.preventDefault();
    let valid = true;

    const fields = ['fullName', 'email', 'phone', 'password', 'confirmPassword'];
    fields.forEach(id => {
      const el = document.getElementById(id);
      if (!el.value.trim()) {
        el.classList.add('is-error');
        valid = false;
      } else {
        el.classList.remove('is-error');
      }
    });

    const pwd  = document.getElementById('password').value;
    const cpwd = document.getElementById('confirmPassword').value;
    if (pwd && cpwd && pwd !== cpwd) {
      document.getElementById('confirmPassword').classList.add('is-error');
      valid = false;
      alert('Passwords match nahi ho rahe!');
      return;
    }

    if (!document.getElementById('terms').checked) {
      alert('Terms & Conditions accept karo pehle!');
      valid = false;
    }

    if (valid) {
      alert('🎉 Registration successful! Welcome to NovaSpark.');
    }
  });

  /* ── Remove error on input ── */
  document.querySelectorAll('.input-custom').forEach(el => {
    el.addEventListener('input', () => el.classList.remove('is-error'));
  });
</script>

</body>
